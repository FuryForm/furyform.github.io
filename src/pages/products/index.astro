---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('product')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Products | FuryForm" description="Explore product releases published as Markdown posts." />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 960px;
				margin: auto;
				padding: 3rem 1rem;
			}
			.product-list {
				display: grid;
				gap: 1rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.product-card {
				display: grid;
				grid-template-columns: minmax(140px, 180px) 1fr;
				gap: 1rem;
				align-items: stretch;
				padding: 1.2rem 1.4rem;
				border-radius: 20px;
				border: 1px solid rgba(255, 255, 255, 0.08);
				background: rgba(255, 255, 255, 0.03);
				box-shadow: var(--box-shadow);
				transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
			}
			.product-card:hover {
				transform: translateY(-2px);
				border-color: rgba(255, 255, 255, 0.16);
				background: rgba(255, 255, 255, 0.05);
			}
			.product-link {
				display: contents;
				color: inherit;
				text-decoration: none;
			}
			.product-icon {
				aspect-ratio: 1 / 1;
				border-radius: 18px;
				overflow: hidden;
				background: rgba(255, 255, 255, 0.08);
				display: grid;
				place-items: center;
			}
			.product-icon img {
				width: 85%;
				height: 85%;
				object-fit: cover;
			}
			.product-copy {
				min-width: 0;
			}
			.product-title {
				margin: 0;
				font-size: 1.4rem;
				color: rgb(var(--black));
			}
			.product-description,
			.product-meta {
				margin: 0.45rem 0 0;
				color: rgb(var(--gray));
				line-height: 1.6;
			}
			.product-meta {
				font-size: 0.95rem;
			}
			.product-card:hover .product-title {
				color: rgb(var(--accent));
			}
			@media (max-width: 720px) {
				.product-card {
					grid-template-columns: 1fr;
					text-align: left;
				}
				.product-icon {
					width: 80px;
					height: 80px;
					margin: 0 auto;
					aspect-ratio: 1 / 1;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul class="product-list">
					{
						posts.map((post) => (
							<li class="product-card">
								<a class="product-link" href={`/products/${post.id}/`}>
									<div class="product-icon">
										<Image
											width={140}
											height={140}
											src={post.data.icon ?? post.data.heroImage}
											alt={`${post.data.title} icon`}
										/>
									</div>
									<div class="product-copy">
										<h4 class="product-title">{post.data.title}</h4>
										<p class="product-description">{post.data.description}</p>
										<p class="product-meta">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
