---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="FuryForm CLI Privacy" description="Privacy policy for the FuryForm CLI." />
	</head>
	<body>
		<Header />
		<main class="container">
			<section class="page-intro">
				<p class="hero-eyebrow">Privacy</p>
				<h1>FuryForm CLI privacy policy</h1>
				<p>The FuryForm CLI generates projects and content templates. It does not transmit or collect user data by default.</p>
			</section>
			<section class="feature-block">
				<h2>How it behaves</h2>
				<ul>
					<li>Runs locally on the developer's machine.</li>
					<li>Creates files, scaffolding, and optional privacy notes as requested.</li>
					<li>Does not send analytics, tracking, or form submissions by default.</li>
				</ul>
			</section>
			<section class="feature-block">
				<h2>Use case guidance</h2>
				<p>If you use the CLI to scaffold a hosted product, include a custom privacy policy for that hosted service or website.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
