---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
<nav class="nav-shell">
<h1><a href="/">{SITE_TITLE}</a></h1>
<div class="internal-links">
<HeaderLink href="/">Home</HeaderLink>
<HeaderLink href="/products">Products</HeaderLink>
<HeaderLink href="/blog">Blog</HeaderLink>
</div>
<button type="button" class="theme-toggle" aria-label="Toggle theme">🌙</button>
</nav>
</header>
<style>
header {
	background: var(--bg);
}

.nav-shell {
display: flex;
align-items: center;
justify-content: space-between;
gap: 1rem;
max-width: min(1100px, calc(100% - 2rem));
margin: 0 auto;
padding: 1.25rem 0;
}

h1 {
margin: 0;
font-size: 1.35rem;
letter-spacing: 0.05em;
}

h1 a {
color: var(--accent);
text-decoration: none;
}

.internal-links {
display: flex;
flex-wrap: wrap;
justify-content: flex-end;
gap: 0.75rem;
}

.theme-toggle {
	background: rgba(255, 255, 255, 0.08);
	color: var(--text);
	border: 1px solid var(--border);
	border-radius: 999px;
	padding: 0.75rem 1rem;
	font: inherit;
	cursor: pointer;
	transition: background-color 0.2s ease, transform 0.2s ease;
}

.theme-toggle:hover,
.theme-toggle:focus-visible {
	background: rgba(255, 255, 255, 0.12);
	outline: none;
}

@media (max-width: 720px) {
.nav-shell {
flex-direction: column;
align-items: stretch;
}
.internal-links {
justify-content: center;
}
}
</style><script>
	const themeKey = 'furyform-theme';
	const root = document.documentElement;
	const toggleButton = () => document.querySelector('.theme-toggle');

	const setTheme = (theme) => {
		if (theme === 'light') {
			root.classList.add('light');
		} else {
			root.classList.remove('light');
		}
		localStorage.setItem(themeKey, theme);
		const button = toggleButton();
		if (button) {
			button.textContent = theme === 'light' ? '🌙 Dark' : '☀️ Light';
		}
	};

	const initTheme = () => {
		const saved = localStorage.getItem(themeKey);
		const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
		const theme = saved || (prefersLight ? 'light' : 'dark');
		setTheme(theme);
	};

	window.addEventListener('DOMContentLoaded', () => {
		initTheme();
		const button = toggleButton();
		if (button) {
			button.addEventListener('click', () => {
				const nextTheme = root.classList.contains('light') ? 'dark' : 'light';
				setTheme(nextTheme);
			});
		}
	});
</script>